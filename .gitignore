# Build output
bin/
out/
dist/
artifacts/
coverage/
build/

# Ignore general build-windows noise but allow specific paths
build-windows/
!official-ubertooth-src/host/build-windows/
official-ubertooth-src/host/build-windows/*
!official-ubertooth-src/host/build-windows/ubertooth-tools/
official-ubertooth-src/host/build-windows/ubertooth-tools/*
!official-ubertooth-src/host/build-windows/ubertooth-tools/src/
official-ubertooth-src/host/build-windows/ubertooth-tools/src/*
!official-ubertooth-src/host/build-windows/ubertooth-tools/src/*.exe
!official-ubertooth-src/host/build-windows/ubertooth-tools/src/*.dll

!official-ubertooth-src/host/build-windows/libubertooth/
official-ubertooth-src/host/build-windows/libubertooth/*
!official-ubertooth-src/host/build-windows/libubertooth/src/
official-ubertooth-src/host/build-windows/libubertooth/src/*
!official-ubertooth-src/host/build-windows/libubertooth/src/*.dll

!official-libbtbb-src/build-windows/
official-libbtbb-src/build-windows/*
!official-libbtbb-src/build-windows/lib/
official-libbtbb-src/build-windows/lib/*
!official-libbtbb-src/build-windows/lib/src/
official-libbtbb-src/build-windows/lib/src/*
!official-libbtbb-src/build-windows/lib/src/*.dll

# Editors
.vscode/
.idea/
*.swp

# OS noise
Thumbs.db
Desktop.ini

# Logs
*.log

# Local agent/runtime state
.omx/
.omc/
official-libwdi-user/

# Official release assets: keep only the validated firmware image used by the repo-local helper
official-release/*
!official-release/ubertooth-2020-12-R1/
official-release/ubertooth-2020-12-R1/*
!official-release/ubertooth-2020-12-R1/ubertooth-one-firmware-bin/
official-release/ubertooth-2020-12-R1/ubertooth-one-firmware-bin/*
!official-release/ubertooth-2020-12-R1/ubertooth-one-firmware-bin/bluetooth_rxtx.dfu
